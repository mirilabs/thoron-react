{
  "compilerOptions": {
    "outDir": "./dist",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react",
    "baseUrl": "src/",
    "paths": {
      "@/*": ["./*"],
    },
    "lib": ["DOM", "ESNext"],
    "downlevelIteration": true
  },
  "include": [
    "src",
    "types"
  ]
}