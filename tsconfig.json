{
  "compilerOptions": {
    "outDir": "./dist",
    "allowJs": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "baseUrl": "src/",
    "jsx": "react",
    "paths": {
      "@/*": ["./src/*"],
    }
  },
  "include": [
    "src",
    "types"
  ]
}